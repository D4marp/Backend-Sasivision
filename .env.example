# Server Configuration
APP_ENV=development
APP_PORT=8080
APP_NAME=SasiVision-API

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=sasivision

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=720h

# CORS Configuration
CORS_ORIGIN=http://localhost:8000,http://localhost:8100,http://app.sasivision.com

# Rate Limiting
RATE_LIMIT_RPS=100

# Auto-run SQL migrations + quiz seed on server start (set false after first deploy in production)
RUN_MIGRATIONS=true
MIGRATIONS_DIR=migrations

# Logging
LOG_LEVEL=debug
